    // 定义相邻大区（用于2-3小时范围）
    const neighborMap = {
        "东北": ["华北"],
        "华北": ["东北", "华东", "西北"],
        "华东": ["华北", "华中", "华南"],
        "华中": ["华东", "华南", "西南"],
        "华南": ["华东", "华中", "西南"],
        "西南": ["华南", "华中", "西北"],
        "西北": ["华北", "西南"],
        "港澳台": ["华南"]
    };

    // 核心过滤函数：根据用户大区 和 交通选项，返回符合距离要求的城市列表
    function filterCitiesByDistance(userRegion, timeOption) {
        if (!userRegion) return citiesDB.slice();
        // 处理“随便多久”直接全部返回
        if (timeOption === "随便多久，说走就走") return citiesDB.slice();

        let allowedRegions = new Set();
        // 1小时以内 → 只允许同大区
        if (timeOption === "1小时以内（家门口溜达）") {
            allowedRegions.add(userRegion);
        }
        // 2-3小时 → 同大区 + 相邻大区
        else if (timeOption === "2-3小时（隔壁省）") {
            allowedRegions.add(userRegion);
            const neighbors = neighborMap[userRegion] || [];
            neighbors.forEach(nei => allowedRegions.add(nei));
        }
        // 4-5小时 或 6小时以上 → 基本上所有区域都允许（半个中国）
        else if (timeOption === "4-5小时（半个中国）" || timeOption === "6小时以上（为了美景飞过去）") {
            return citiesDB.slice();
        }
        else {
            // 兜底
            return citiesDB.slice();
        }

        // 过滤城市
        let filtered = citiesDB.filter(city => allowedRegions.has(city.region));
        // 如果过滤后为空（比如用户选了1h但所在大区没有城市，理论上不可能华东华北都有城市），则回退到相邻大区或全部
        if (filtered.length === 0) {
            if (timeOption === "1小时以内（家门口溜达）") {
                // 尝试扩大到相邻大区并给提示
                const neighbors = neighborMap[userRegion] || [];
                let fallback = citiesDB.filter(c => neighbors.includes(c.region) || c.region === userRegion);
                if (fallback.length) return fallback;
                else return citiesDB.slice();
            }
            return citiesDB.slice();
        }
        return filtered;
    }

