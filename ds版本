    function getPersonalityTitle(scores) {
        let { social, open, plan, food, active } = scores;
        if (social > 1.5 && open > 1 && active > 1) return "🔥 狂野榴莲冲锋粽 🔥";
        if (social < -1 && active < -0.5) return "🍃 佛系白米蘸糖粽 🍃";
        if (plan > 1.5 && open < 0) return "📝 强迫症红豆计划粽 📝";
        if (open > 1.8 && food > 1) return "🦞 探险小龙虾暗黑粽 🦞";
        if (social > 1 && food > 1.5) return "🎉 社交牛肉蛋黄粽 🎉";
        if (active > 1.5 && social > 0.5) return "🚣 龙舟竞渡肌肉粽 🚣";
        if (active < -1 && food > 0) return "😴 葛优躺枕头粽 😴";
        if (open < -1 && plan > 0) return "🏮 传统守旧碱水粽 🏮";
        return "🐣 端午神秘粽 · 可盐可甜 🐣";
    }

    // 渲染表单
    function renderForm() {
        const formContainer = document.getElementById("quizForm");
        let html = "";
        questions.forEach((q, idx) => {
            html += `<div class="question-box"><div class="question-text">${q.text}</div><div class="options">`;
            if (q.type === "location" || q.type === "time") {
                q.options.forEach(opt => {
                    const safeId = `q${idx}_${opt.replace(/[\s\(\)]/g, '')}`;
                    html += `<div class="option"><input type="radio" name="q${idx}" value="${opt}" id="${safeId}"><label for="${safeId}">${opt}</label></div>`;
                });
            } else {
                q.mapping.forEach((opt, oidx) => {
                    html += `<div class="option"><input type="radio" name="q${idx}" value="${oidx}" id="q${idx}_${oidx}"><label for="q${idx}_${oidx}">${opt.text}</label></div>`;
                });
            }
            html += `</div></div>`;
        });
        formContainer.innerHTML = html;
    }

    // 计算推荐结果
    function computeResult() {
        let userRegion = null;
        let travelTime = null;
        let psyScores = { social: 0, open: 0, plan: 0, food: 0, active: 0 };
        let psyCount = 0;

        for (let i = 0; i < questions.length; i++) {
            const radios = document.getElementsByName(`q${i}`);
            let selected = null;
            for (let r of radios) if (r.checked) { selected = r.value; break; }
            if (!selected) {
                alert(`请完成第${i+1}题哦 🎋`);
                return null;
            }
            if (i === 0) userRegion = selected;
            else if (i === 1) travelTime = selected;
            else {
                const idx = parseInt(selected);
                const mapping = questions[i].mapping[idx];
                if (mapping && mapping.points) {
                    for (let [dim, val] of Object.entries(mapping.points)) {
                        if (psyScores.hasOwnProperty(dim)) psyScores[dim] += val;
                    }
                }
                psyCount++;
            }
        }

        for (let k in psyScores) psyScores[k] = psyScores[k] / psyCount;

        // 根据距离筛选候选城市
        let candidates = filterCitiesByDistance(userRegion, travelTime);
        // 人格分数归一化到1-5范围（原范围大约-3~3）
        const userVec = {
            social: Math.min(5, Math.max(1, 3 + psyScores.social)),
            open: Math.min(5, Math.max(1, 3 + psyScores.open)),
            plan: Math.min(5, Math.max(1, 3 + psyScores.plan)),
            food: Math.min(5, Math.max(1, 3 + psyScores.food)),
            active: Math.min(5, Math.max(1, 3 + psyScores.active))
        };

        // 匹配最佳城市（欧氏距离倒数）
        let bestCity = null;
        let bestScore = -Infinity;
        for (let city of candidates) {
            const s = city.scores;
            const dist = Math.sqrt(
                Math.pow(userVec.social - s.social, 2) +
                Math.pow(userVec.open - s.open, 2) +
                Math.pow(userVec.plan - s.plan, 2) +
                Math.pow(userVec.food - s.food, 2) +
                Math.pow(userVec.active - s.active, 2)
            );
            const similarity = 1 / (1 + dist);
            if (similarity > bestScore) {
                bestScore = similarity;
                bestCity = city;
            }
        }

        if (!bestCity) bestCity = candidates[0] || citiesDB[0];

        const title = getPersonalityTitle(psyScores);
        const distanceHint = (travelTime === "1小时以内（家门口溜达）") ? "🌟 就在你家大区附近，随时走起！" : (travelTime === "2-3小时（隔壁省）" ? "🚄 邻省可达，周末毫无压力" : "✈️ 为了完美的端午，稍微走远也值得");
        const reasonText = `🎋 根据你的端午人格，${bestCity.name} 简直是为你量身定制！${bestCity.desc}。${distanceHint} 当地端午氛围浓郁，${bestCity.hot ? "热门旅行地，活动超丰富" : "小众宝藏，人少体验独特"}。带上这份粽力推荐，出发吧！`;

        return { city: bestCity, title, reason: reasonText };
    }

    function showResult() {
        const res = computeResult();
        if (!res) return;
        document.getElementById("resultCity").innerText = res.city.name;
        document.getElementById("personalityTitle").innerHTML = `🍙 ${res.title} 🍙`;
        document.getElementById("resultImg").src = res.city.img;
        document.getElementById("resultReason").innerHTML = res.reason;
        document.getElementById("quizPanel").classList.add("hidden");
        document.getElementById("resultPanel").classList.remove("hidden");
    }

    function resetQuiz() {
        const radios = document.querySelectorAll('input[type="radio"]');
        radios.forEach(r => r.checked = false);
        document.getElementById("quizPanel").classList.remove("hidden");
        document.getElementById("resultPanel").classList.add("hidden");
    }

    window.onload = () => {
        renderForm();
        document.getElementById("submitBtn").addEventListener("click", showResult);
        document.getElementById("resetBtn").addEventListener("click", resetQuiz);
        document.getElementById("restartBtn").addEventListener("click", resetQuiz);
    };
</script>
</body>
