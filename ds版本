        { name:"广州", region:"华南", hot:true,  desc:"珠三角龙舟漂移，荔枝粽", img:"https://picsum.photos/id/30/300/200", scores:{social:5, open:4, plan:2, food:5, active:4} },
        { name:"南京", region:"华东", hot:true,  desc:"秦淮河龙舟，端午市集", img:"https://picsum.photos/id/20/300/200", scores:{social:4, open:3, plan:3, food:4, active:3} },
